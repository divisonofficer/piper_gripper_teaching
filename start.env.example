# Copy this file to .env and edit it for your workstation.
#
# cp start.env.example .env
# ./start.sh

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5002
HTTPS_PORT=5003

# Python. Leave empty to auto-use .venv/bin/python when present, else python3.
# PYTHON_BIN=/path/to/python

# ROS / Piper driver
PIPER_START_ROS=1
PIPER_ROS_PACKAGE=piper
PIPER_ROS_EXECUTABLE=piper_single_ctrl

# Colon-separated setup.bash files to source before running ros2.
# Example:
# PIPER_ROS_SETUP_FILES=/opt/ros/humble/setup.bash:/home/user/piper_ws/install/setup.bash
PIPER_ROS_SETUP_FILES=/opt/ros/humble/setup.bash

# CAN
PIPER_ACTIVATE_CAN=1
CAN_PORT=can1
CAN_BITRATE=1000000
PIPER_CAN_USB=1-2:1.0

# Piper_ros repository containing can_activate.sh.
PIPER_WS_DIR=/home/user/piper_ws/src/Piper_ros

# Piper driver parameters
PIPER_AUTO_ENABLE=true
PIPER_GRIPPER_EXIST=true

# Frontend. Set to 1 on first install if frontend/build is missing.
PIPER_BUILD_FRONTEND=0
